{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ES2020",
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "allowSyntheticDefaultImports": true,
        "types": []
    },
    "include": [
        "bootstrap.js",
        "consent.js",
        "saudade-*.js",
        "saudade.*.js",
        "cloudflare-worker.js",
        "scripts/*.js",
        "types.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "data"
    ]
}
